{
  "manifest_version": 3,
  "name": "Gefahrstoff Fernbedienung",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "http://localhost:3000/*"
  ]
}
