// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Modul 1: Mandanten ---
model Tenant {
  id        String     @id @default(uuid())
  name      String
  
  // Modul 15: Vererbbare Zuständigkeiten (Default für alle Unterebenen)
  sifaName         String?
  betriebsarztName String?
  auditorName      String?

  // Modul: SDB Management & Fristen
  sdbReviewMode    String   @default("INDIVIDUAL") // INDIVIDUAL oder MASS
  sdbMassReviewDate DateTime? // Globaler Stichtag für Massenprüfung

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  locations Location[]
  documents Document[]
  legalSettings LegalSettings?
}

// --- Modul 13: Impressum & DSGVO & SMTP ---
model LegalSettings {
  id              String @id @default(uuid())
  tenantId        String @unique
  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName     String
  legalForm       String
  representatives String
  address         String
  contact         String
  registerInfo    String?
  primaryColor    String?  @default("#0f172a")
  logoBase64      String?  // base64 encoded image
  aiProvider      String?
  aiApiKey        String?
  // SMTP-Konfiguration (E-Mail-Versand)
  smtpProvider    String?  // z.B. "microsoft365", "google", "custom"
  smtpHost        String?
  smtpPort        Int?
  smtpSecure      Boolean? @default(false) // true = TLS (465), false = STARTTLS (587)
  smtpUser        String?
  smtpPass        String?  // Verschlüsselt gespeichert
  smtpFrom        String?  // Absender-Adresse
  // SSO-Konfiguration (Modul 22)
  ssoEnabled      Boolean? @default(false)
  ssoProvider     String?  // "oidc" oder "saml"
  ssoClientId     String?
  ssoClientSecret String?  // Verschlüsselt
  ssoIssuerUrl    String?  // z.B. https://login.microsoftonline.com/{tenantId}/v2.0
  ssoCallbackUrl  String?  // z.B. http://localhost:3000/api/auth/sso/callback
  ssoGroupMapping String?  // JSON: {"AD-Gruppe": "ADMIN", "Viewer-Gruppe": "VIEWER"}
}

model Location {
  id        String @id @default(uuid())
  name      String
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Modul 15: Vererbbare Zuständigkeiten (Override für diesen Standort)
  sifaName         String?
  betriebsarztName String?
  auditorName      String?

  constructionYear Int?
  asbestosStatus   String? 

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  workAreas    WorkArea[]
  documents    Document[]
  asbestosFindings AsbestosFinding[]
  RevisionTask RevisionTask[]
  users        User[]
}

// --- Modul 23: Asbest-Kataster (TRGS 519) ---
model AsbestosFinding {
  id          String   @id @default(uuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  component   String   // z.B. Floor-Flex-Platten, Fliesenkleber
  exactSpot   String   // Freitext, z.B. "Heizungskeller, Wand X"
  status      String   // z.B. "Suspected", "Confirmed", "Remediated"
  notes       String?
  exposedEmployees Employee[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkArea {
  id         String   @id @default(uuid())
  name       String
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Hierarchie (Unterbereiche)
  parentId   String?
  parent     WorkArea?  @relation("WorkAreaHierarchy", fields: [parentId], references: [id])
  children   WorkArea[] @relation("WorkAreaHierarchy")

  // Modul 15: Vererbbare Zuständigkeiten (Override für diesen Arbeitsbereich)
  sifaName         String?
  betriebsarztName String?
  auditorName      String?

  // Modul 4: Vorsorge-Planer
  isFeuchtarbeit      Boolean @default(false)
  dailyExposureHours  Float?

  // Finale Module: Staub & Gas
  dustExposureType String?
  gasType          String?
  roomVolume       Float?

  // Modul 6: Audit & Inventory
  inventories      LocalSubstanceInventory[]
  auditLogs        AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hazardousSubstances  HazardousSubstance[]
  biologicalSubstances BiologicalSubstance[]
  documents            Document[]
  vorsorgeReports      VorsorgeReport[]
  snapshots            GbuSnapshot[]
}

// --- Modul 6: User & RBAC ---
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("VIEWER")  // ADMIN, SAFETY_OFFICER, LOCATION_MANAGER, VIEWER
  status       String   @default("PENDING_APPROVAL") // PENDING_APPROVAL, ACTIVE, SUSPENDED
  firstName    String?
  lastName     String?
  tokenVersion Int      @default(0) // Increment → invalidates all issued JWTs
  preferences  String?  // JSON String für UI-Settings
  
  locations    Location[]
  auditLogs    AuditLog[]
  resetTokens  PasswordResetToken[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- Modul: Password Reset Tokens ---
model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique  // crypto.randomBytes(64).toString('hex')
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  // now() + 1h
  usedAt    DateTime? // null = unused, set on consumption (single-use)
  createdAt DateTime  @default(now())
}

// --- Modul 6: Daten-Trennung (Phase 1) ---
model HazardousSubstanceMaster {
  id           String   @id @default(uuid())
  productName  String
  manufacturer String?
  substanceType String  @default("GEFAHRSTOFF") // GEFAHRSTOFF, BIOSTOFF, ASBEST, HAUTSCHUTZ, GASFLASCHE
  isMixture    Boolean  @default(false)
  hPhrases     String   
  emkgRating   String?
  agwValue     String?  // Auch für MAK, DNEL, BGW
  wgk          Int?     // 1, 2, 3
  storageClass String?  // TRGS 510 LGK (z.B. "3", "8A", "10")
  storageIncompatibilities String?  // Zusammenlagerungsverbote (Abschnitt 7.2)
  incompatibleMaterials    String?  // Unverträgliche Materialien (Abschnitt 10.5)
  // Modul: SDB Management & Fristen
  sdbDate                DateTime?
  sdbFilePath            String?
  nextReviewDate         DateTime?
  responsiblePerson      String?
  autoMailToManufacturer Boolean   @default(false)
  autoMailAdvanceDays    Int       @default(30)
  manufacturerEmail      String?
  lastManufacturerMailDate DateTime?
  
  isKrebserzeugend       Boolean @default(false)
  isMutagen              Boolean @default(false)
  isReproduktionstoxisch Boolean @default(false)
  isMutterschutzRelevant Boolean @default(false)
  isJugendschutzRelevant Boolean @default(false)
  isAcuteToxic           Boolean @default(false)

  inventories            LocalSubstanceInventory[]
  employeeExposures      EmployeeExposure[]
  trainingModules        TrainingModule[]
  profileItems           SubstanceProfileItem[]
  revisionTasks          RevisionTask[]
  snapshots              SubstanceSnapshot[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model LocalSubstanceInventory {
  id                String   @id @default(uuid())
  workAreaId        String
  workArea          WorkArea @relation(fields: [workAreaId], references: [id], onDelete: Cascade)
  
  masterSubstanceId String
  masterSubstance   HazardousSubstanceMaster @relation(fields: [masterSubstanceId], references: [id])
  
  annualAmount      Float?   // Menge für Unit Leader
  usageDescription  String?  // Lokaler Zweck
  mediaUrls         String?  // SQLite kompatibel: String statt String[]
  status            String   @default("ACTIVE")
  
  // Modul 15: Zuständigkeiten (Spezifischer Override für diesen Stoff)
  sifaName         String?
  betriebsarztName String?
  involvedPersons  String? // Beteiligte Personen bei der GBU

  // Modul 8: Compliance-Felder
  substitutionCheck String?  // TRGS 600
  maxStorageAmount  Float?   // TRGS 510

  // Modul 9: Dynamische Datenfelder
  customFields      String?  // SQLite: JSON als Text speichern

  // Modul 18: Four-Eyes Principle (Juristische Freigabe)
  juridicalApprovalBy String?
  juridicalApprovalAt DateTime?

  // Modul 20: GBU & EMKG Daten (BauA)
  activityName      String?
  physicalState     String?  // Feststoff, Flüssigkeit, Gas
  emkgInhalation    String?
  emkgSkin          String?
  emkgFire          String?
  
  // Modul 20: STOP-Prinzip Maßnahmen
  stopSubstitution  String?
  stopTechnical     String?
  stopOrganizational String?
  stopPersonal      String?
  reviewDate        DateTime?

  // Dynamische Weichen (Biostoffe, Asbest)
  bioTargetedActivity Boolean?
  bioRiskGroup        String?
  asbestosActivity    String? // "Grosstätigkeit", "Kleinsttätigkeit"
  asbestosBinding     String? // "Fest", "Schwach"
  btVerfahren         String?
  gasStorageType      String?

  // TRGS 401 (Hautschutz & Feuchtarbeit)
  skinDirtType        String? // wasserlöslich, fettlöslich, haftend
  skinCleaningAgents  String? // mild, lösemittel, abrasiva, kombi
  skinWashingFreq     String? // <5, 5-15, >15
  skinGloveDuration   String? // <2h, 2-4h, >4h

  notes               String? // Eigene Bemerkungen des Nutzers

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  media             SubstanceMedia[]
  documents         Document[]
  effectivenessChecks EffectivenessCheck[]
}

// Modul 20: EMKG Wirksamkeitsprüfung (Schutzleitfäden)
model EffectivenessCheck {
  id              String   @id @default(uuid())
  inventoryId     String?
  inventory       LocalSubstanceInventory? @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  
  biologicalSubstanceId String?
  biologicalSubstance   BiologicalSubstance? @relation(fields: [biologicalSubstanceId], references: [id], onDelete: Cascade)

  guidelineCode   String
  title           String
  auditor         String?
  checkedAt       DateTime?
  nextReviewDate  DateTime?
  notes           String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Modul: Medien & Notizen
model SubstanceMedia {
  id              String   @id @default(uuid())
  inventoryId     String
  inventory       LocalSubstanceInventory @relation(fields: [inventoryId], references: [id])
  mediaType       String   @default("IMAGE") // IMAGE, VIDEO
  url             String
  description     String?
  
  createdAt       DateTime @default(now())
}

// Modul: Dokumenten-Center (Betriebsanweisungen, Hautschutzpläne)
model OperatingInstruction {
  id              String   @id @default(uuid())
  title           String
  documentType    String   @default("BETRIEBSANWEISUNG") // BA, HAUTSCHUTZPLAN, GEFAEHRDUNGSBEURTEILUNG
  level           String   @default("TENANT") // GLOBAL, TENANT, WORK_AREA
  tenantId        String?
  workAreaId      String?
  fileUrl         String   // Pfad/Mock-URL zum Dokument
  isApprovedByAdmin Boolean @default(false)
  uploadedBy      String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- Audit-Log (Modul 6) — Revisionssicher mit Hash-Kette ---
model AuditLog {
  id        String   @id @default(uuid())
  seqNo     Int?     @unique // Lückenlose Sequenz für Forensik (app-managed, null für Legacy-Einträge)
  action    String   
  details   String
  hashRef   String?  
  hash      String?  // SHA256 dieses Eintrags
  prevHash  String?  // SHA256 des vorherigen Eintrags (Blockchain-Kette)
  entityId  String?  
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  workAreaId String?
  workArea   WorkArea? @relation(fields: [workAreaId], references: [id])
  
  ipAddress String
  timestamp DateTime @default(now())
}

// --- Restliche Bestandsmodelle (Migration ausstehend) ---
model HazardousSubstance {
  id           String   @id @default(uuid())
  productName  String
  manufacturer String?
  hPhrases     String 
  emkgRating   String?
  agwValue     String? 
  workAreaId   String
  workArea     WorkArea @relation(fields: [workAreaId], references: [id], onDelete: Cascade)

  isKrebserzeugend       Boolean @default(false)
  isMutagen              Boolean @default(false)
  isReproduktionstoxisch Boolean @default(false)
  isMutterschutzRelevant Boolean @default(false)
  isJugendschutzRelevant Boolean @default(false)
  isAcuteToxic           Boolean @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  documents      Document[]
  vorsorgeReports VorsorgeReport[]
}

model BiologicalSubstance {
  id              String   @id @default(uuid())
  name            String
  riskGroup       Int
  protectionLevel Int
  isTargetedActivity Boolean @default(false)
  transmissionPath   String?
  vaccinationOffer   String?
  notes              String?
  workAreaId         String
  workArea        WorkArea @relation(fields: [workAreaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  documents       Document[]
  effectivenessChecks EffectivenessCheck[]
}

model Document {
  id           String @id @default(uuid())
  originalName String
  filename     String
  path         String
  mimeType     String
  docType      String

  tenantId              String?
  tenant                Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationId            String?
  location              Location?           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  workAreaId            String?
  workArea              WorkArea?           @relation(fields: [workAreaId], references: [id], onDelete: Cascade)
  hazardousSubstanceId  String?
  hazardousSubstance    HazardousSubstance? @relation(fields: [hazardousSubstanceId], references: [id], onDelete: Cascade)
  biologicalSubstanceId String?
  biologicalSubstance   BiologicalSubstance? @relation(fields: [biologicalSubstanceId], references: [id], onDelete: Cascade)
  inventoryId           String?
  inventory             LocalSubstanceInventory? @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  
  trainingModules       TrainingModule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VorsorgeReport {
  id                   String              @id @default(uuid())
  workAreaId           String
  workArea             WorkArea            @relation(fields: [workAreaId], references: [id], onDelete: Cascade)
  hazardousSubstanceId String?
  hazardousSubstance   HazardousSubstance? @relation(fields: [hazardousSubstanceId], references: [id], onDelete: Cascade)

  type                 String 
  trigger              String
  status               String @default("Offen")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Regulation {
  id              String  @id @default(uuid())
  ruleId          String
  category        String
  triggerHPhrases String
  isMutterschutzRelevant Boolean @default(false)
  isJugendschutzRelevant Boolean @default(false)
  isAsbestRelevant        Boolean @default(false)
  reference       String
  muSchGNote      String?

  limitValue  String?
  versionDate DateTime @default(now())
  status      String   @default("ACTIVE")

  revisionTasks RevisionTask[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RevisionTask {
  id           String     @id @default(uuid())
  regulationId String?
  regulation   Regulation? @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  hazardousSubstanceId String?
  hazardousSubstance   HazardousSubstanceMaster? @relation(fields: [hazardousSubstanceId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  status       String @default("PENDING")
  adminComment String?
  confirmedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GbuSnapshot {
  id           String   @id @default(uuid())
  workAreaId   String
  workArea     WorkArea @relation(fields: [workAreaId], references: [id], onDelete: Cascade)
  snapshotData String
  snapshotHash String   @unique
  reason       String
  createdAt    DateTime @default(now())
}

// --- Modul 21: Personal & ArbMedVV (ZED/ODIN) ---

model Employee {
  id              String             @id @default(uuid())
  firstName       String
  lastName        String
  employeeNumber  String?            // Personalnummer
  pin             String?            // 4-stellige PIN für den Login (Kiosk-Modus)
  email           String?
  phone           String?
  dateOfBirth     DateTime?
  department      String?            // z.B. "Haustechnik"
  manualVorsorgen String?            // JSON-Liste oder kommagetrennte Strings für manuelle ArbMedVV Tags (z.B. G 37)
  
  supervisorId    String?
  supervisor      Employee?          @relation("SupervisorRelation", fields: [supervisorId], references: [id])
  subordinates    Employee[]         @relation("SupervisorRelation")

  exposures       EmployeeExposure[]
  trainingRecords EmployeeTrainingRecord[]
  readConfirmations ReadConfirmation[]
  notifications    NotificationTask[]
  asbestosFindings AsbestosFinding[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model EmployeeExposure {
  id                 String                   @id @default(uuid())
  employeeId         String
  employee           Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  masterSubstanceId  String
  masterSubstance    HazardousSubstanceMaster @relation(fields: [masterSubstanceId], references: [id], onDelete: Cascade)
  
  exposureType       String                   @default("GEFAHRSTOFF") // GEFAHRSTOFF, BIOSTOFF
  vorsorgeFrist      String?                  // z.B. "G 24 Haut", "G 20 Lärm"
  nextVorsorgeDate   DateTime?
  notes              String?
  assignedAt         DateTime                 @default(now())
}

model NotificationTask {
  id               String   @id @default(uuid())
  type             String   // "REMINDER_EMPLOYEE", "ESCALATION_SUPERVISOR"
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  trainingRecordId String?
  status           String   @default("PENDING") // PENDING, SENT, FAILED
  sendAfter        DateTime
  sentAt           DateTime?
  errorLog         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// --- Modul 22: LMS & Unterweisungen ---
model TrainingModule {
  id              String   @id @default(uuid())
  title           String
  description     String?
  targetAudience  String?  // z.B. "Alle", "Reinigungskräfte", "Asbest-Sanierer"
  sortOrder       Int      @default(0) // Für Drag & Drop Sortierung
  
  // Verknüpfung zu Gefährdungsquellen (Gefahrstoff, Biostoff, Asbest)
  hazardousSubstanceId String?
  hazardousSubstance   HazardousSubstanceMaster? @relation(fields: [hazardousSubstanceId], references: [id], onDelete: SetNull)
  
  content         String?  // JSON string für Folien/Text (Admin-Editor)
  quizQuestions   String?  // JSON string für Quiz-Fragen
  
  externalFormUrl String?  // Optionaler Link zu MS/Google Forms
  webhookSecret   String?  // Für sichere Übertragung von externen Formularen
  
  documents       Document[] // Angehängte Betriebsanweisungen oder PDFs
  records         EmployeeTrainingRecord[]
  trainingNeeds   TrainingNeed[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TrainingNeed {
  id               String   @id @default(uuid())
  substanceName    String   
  substanceType    String   // GEFAHRSTOFF, BIOSTOFF, ASBEST
  workAreaName     String?  
  status           String   @default("PENDING") // PENDING, RESOLVED
  
  trainingModuleId String?
  trainingModule   TrainingModule? @relation(fields: [trainingModuleId], references: [id], onDelete: SetNull)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model EmployeeTrainingRecord {
  id               String         @id @default(uuid())
  employeeId       String
  employee         Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  trainingModuleId String
  trainingModule   TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Cascade)
  
  status           String         @default("ASSIGNED") // ASSIGNED, IN_PROGRESS, COMPLETED, FAILED
  score            Float?
  completedAt      DateTime?
  validUntil       DateTime?
  certificateHash  String?        // Fälschungssicherer Hash

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// --- Modul: Gefahrstoff-Profile ---

model SubstanceProfile {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  items       SubstanceProfileItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SubstanceProfileItem {
  id                 String @id @default(uuid())
  profileId          String
  profile            SubstanceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  // Für Gefahrstoffe
  masterSubstanceId  String?
  masterSubstance    HazardousSubstanceMaster? @relation(fields: [masterSubstanceId], references: [id], onDelete: Cascade)
  
  // Für Biostoffe
  isBiological       Boolean @default(false)
  bioName            String?
  bioRiskGroup       Int?
  bioTargeted        Boolean @default(false)
}

// --- Modul 11: Digitale Lesebestätigung ---
model ReadConfirmation {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentId      String?  // Optionaler Bezug auf ein Dokument (BA)
  substanceId     String?  // Optionaler Bezug auf ein LocalSubstanceInventory
  substanceName   String?  // Klartextname für Audit-Zwecke
  confirmedAt     DateTime @default(now())
  ipAddress       String?
}

// --- Modul 22: Stoff-Historisierung (Freeze-State bei SDB-Änderung) ---
model SubstanceSnapshot {
  id                  String   @id @default(uuid())
  masterSubstanceId   String
  masterSubstance     HazardousSubstanceMaster @relation(fields: [masterSubstanceId], references: [id], onDelete: Cascade)
  snapshotData        String   // Vollständiger JSON-Dump aller Felder zum Zeitpunkt der Änderung
  reason              String   // z.B. "SDB_UPDATE", "REVISION", "MANUAL_FREEZE"
  createdBy           String?  // User-E-Mail
  snapshotHash        String   // SHA256 über snapshotData für Integritätsprüfung
  createdAt           DateTime @default(now())
}

// --- Modul 22: SSO Gruppen-Mapping ---
model SsoMapping {
  id            String @id @default(uuid())
  adGroupName   String @unique
  systemRole    String // ADMIN, UNIT_LEADER, VIEWER, etc.
  locationId    String? // Optionaler Standort-Bezug
  createdAt     DateTime @default(now())
}